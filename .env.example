# .env  —  Aura Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to git.

# ─── API ──────────────────────────────────────────────────────────────────────
AURA_API_URL=http://localhost:8000
AURA_SECRET_KEY=aura-3g2b-orchestron-change-this-in-prod

# ─── FRONTEND ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# ─── DATABASE ─────────────────────────────────────────────────────────────────
LEDGER_PATH=database/ledger.json

# ─── LLM (optional — for real LangChain LLM reasoning) ───────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_PROVIDER=openai   # or: anthropic | local

# ─── STREAMLIT ────────────────────────────────────────────────────────────────
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true
